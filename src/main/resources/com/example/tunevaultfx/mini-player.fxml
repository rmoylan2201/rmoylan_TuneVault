<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.tunevaultfx.controllers.MiniPlayerController"
      alignment="CENTER_LEFT"
      spacing="14"
      style="-fx-background-color: #111827; -fx-padding: 14 18 14 18;">

    <children>
        <VBox spacing="2"
              prefWidth="210"
              onMouseClicked="#handleOpenSongDetails"
              style="-fx-cursor: hand;">
            <children>
                <Label fx:id="miniSongLabel"
                       text="No song playing"
                       style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" />
                <Label fx:id="miniArtistLabel"
                       text=""
                       style="-fx-text-fill: #cbd5e1; -fx-font-size: 12px;" />
                <Hyperlink fx:id="miniPlaylistLink"
                           text=""
                           onAction="#handleOpenCurrentPlaylist"
                           prefWidth="190"
                           style="-fx-text-fill: #93c5fd; -fx-font-size: 11px;" />
            </children>
        </VBox>

        <VBox alignment="CENTER" spacing="6" prefWidth="360">
            <children>
                <Slider fx:id="miniProgressSlider" prefWidth="340" />

                <HBox alignment="CENTER" spacing="12">
                    <children>
                        <Button fx:id="miniShuffleButton"
                                text="🔀"
                                onAction="#handleMiniShuffle"
                                prefWidth="50"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 16px; -fx-border-color: transparent; -fx-background-radius: 10;" />

                        <Button fx:id="miniPreviousButton"
                                text="&lt;"
                                onAction="#handleMiniPrevious"
                                prefWidth="42"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 18px; -fx-border-color: transparent; -fx-background-radius: 10;" />

                        <Button fx:id="miniPlayPauseButton"
                                text="▶"
                                onAction="#handleMiniPlayPause"
                                prefWidth="50"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 18px; -fx-border-color: transparent; -fx-background-radius: 10;" />

                        <Button fx:id="miniNextButton"
                                text="&gt;"
                                onAction="#handleMiniNext"
                                prefWidth="42"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 18px; -fx-border-color: transparent; -fx-background-radius: 10;" />

                        <Button fx:id="miniLoopButton"
                                text="🔁"
                                onAction="#handleMiniLoop"
                                prefWidth="50"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 16px; -fx-border-color: transparent; -fx-background-radius: 10;" />

                        <Button fx:id="miniLikeButton"
                                text="♡"
                                onAction="#handleMiniLike"
                                prefWidth="56"
                                style="-fx-background-color: transparent; -fx-text-fill: #f59e0b; -fx-font-size: 20px; -fx-border-color: transparent; -fx-background-radius: 10;" />
                    </children>
                </HBox>

                <Label fx:id="miniTimeLabel"
                       text="0:00 / 0:00"
                       style="-fx-text-fill: #cbd5e1; -fx-font-size: 11px;" />
            </children>
        </VBox>

        <Region HBox.hgrow="ALWAYS" />

        <Button text="Open Now Playing"
                onAction="#handleOpenNowPlaying"
                prefWidth="145"
                style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-background-radius: 10;" />
    </children>
</HBox>