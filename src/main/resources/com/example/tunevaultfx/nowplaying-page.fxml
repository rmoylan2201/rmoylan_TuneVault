<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.NowPlayingPageController"
            prefWidth="900" prefHeight="650"
            style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #1e293b);">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 20;">
            <Label text="Now Playing"
                   style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" />
            <Button text="Back to Menu"
                    onAction="#handleBackToMenu"
                    style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-background-radius: 20;" />
            <Button text="Back to Playlists"
                    onAction="#handleBackToPlaylists"
                    style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-background-radius: 20;" />
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 30;">
            <VBox alignment="CENTER" spacing="15"
                  maxWidth="550"
                  style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 30;">

                <Region prefWidth="200" prefHeight="200"
                        style="-fx-background-color: #dbeafe; -fx-background-radius: 20;" />

                <Label fx:id="titleLabel"
                       text="No song playing"
                       style="-fx-font-size: 26px; -fx-font-weight: bold;" />
                <Label fx:id="artistLabel"
                       text=""
                       style="-fx-font-size: 18px; -fx-text-fill: #475569;" />
                <Label fx:id="albumLabel"
                       text="Album: -"
                       style="-fx-font-size: 16px; -fx-text-fill: #64748b;" />

                <Slider fx:id="progressSlider" prefWidth="400" />
                <Label fx:id="timeLabel"
                       text="0:00 / 0:00"
                       style="-fx-font-size: 14px; -fx-text-fill: #64748b;" />

                <HBox alignment="CENTER" spacing="12">
                    <Button fx:id="shuffleButton"
                            text="Shuffle Off"
                            onAction="#handleShuffle"
                            style="-fx-background-color: #475569; -fx-text-fill: white; -fx-background-radius: 20;" />

                    <Button text="Previous"
                            onAction="#handlePrevious"
                            style="-fx-background-color: #1d4ed8; -fx-text-fill: white; -fx-background-radius: 20;" />

                    <Button fx:id="playPauseButton"
                            text="Play"
                            onAction="#handlePlayPause"
                            style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-background-radius: 20;" />

                    <Button text="Next"
                            onAction="#handleNext"
                            style="-fx-background-color: #1d4ed8; -fx-text-fill: white; -fx-background-radius: 20;" />

                    <Button fx:id="loopButton"
                            text="Loop Off"
                            onAction="#handleLoop"
                            style="-fx-background-color: #475569; -fx-text-fill: white; -fx-background-radius: 20;" />
                </HBox>

                <HBox alignment="CENTER" spacing="12">
                    <Button fx:id="likeButton"
                            text="Like ♡"
                            onAction="#handleLike"
                            style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-background-radius: 20;" />

                    <Button text="Add to Playlist"
                            onAction="#handleAddToPlaylist"
                            style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-background-radius: 20;" />
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>