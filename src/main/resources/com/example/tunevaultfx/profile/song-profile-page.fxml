<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.search.SongProfileController"
            prefWidth="1280.0" prefHeight="820.0"
            styleClass="page-bg">

    <top>
        <fx:include source="../chrome/app-top-bar.fxml"/>
    </top>

    <left>
        <fx:include source="../chrome/app-sidebar.fxml"/>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    styleClass="song-profile-scroll">
            <content>
                <VBox spacing="20" style="-fx-padding: 20 32 28 32;" maxWidth="Infinity">
                    <children>

                        <HBox spacing="28" alignment="CENTER_LEFT" styleClass="hero-gradient">
                            <children>
                                <StackPane prefWidth="100" prefHeight="100"
                                           minWidth="100" minHeight="100"
                                           styleClass="artist-avatar">
                                    <Label text="♪"
                                           style="-fx-font-size: 40px; -fx-text-fill: rgba(255,255,255,0.5);"/>
                                </StackPane>
                                <VBox spacing="8" HBox.hgrow="ALWAYS">
                                    <Label text="TRACK" styleClass="overline"/>
                                    <Label fx:id="songTitleLabel" text="—"
                                           styleClass="heading-xl"
                                           wrapText="true"
                                           style="-fx-font-size: 34px;"/>
                                    <HBox alignment="CENTER_LEFT" spacing="0">
                                        <Hyperlink fx:id="songArtistLink" onAction="#handleArtistNameClick"
                                                   styleClass="body-sm, song-profile-artist-link"
                                                   wrapText="false" focusTraversable="true"/>
                                        <Label fx:id="songMetaTailLabel" text=""
                                               styleClass="body-sm" wrapText="true"/>
                                    </HBox>
                                    <HBox spacing="12" alignment="CENTER_LEFT">
                                        <Button fx:id="playSongButton" text="Play"
                                                onAction="#handlePlay"
                                                styleClass="btn-primary"
                                                minHeight="40" prefHeight="40"
                                                maxWidth="200" focusTraversable="false"/>
                                        <Button fx:id="likeSongButton" text="♡ Save"
                                                onAction="#handleLike"
                                                styleClass="btn-ghost"
                                                minHeight="40" prefHeight="40"
                                                focusTraversable="false"/>
                                        <Button fx:id="addSongButton" text="Add to playlist"
                                                onAction="#handleAddToPlaylist"
                                                styleClass="btn-ghost"
                                                minHeight="40" prefHeight="40"
                                                focusTraversable="false"/>
                                    </HBox>
                                </VBox>
                            </children>
                        </HBox>

                        <VBox fx:id="relatedSection" spacing="14" styleClass="card" maxWidth="Infinity">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <StackPane styleClass="icon-box-sm, icon-box-violet">
                                        <Label text="≋" styleClass="text-accent"/>
                                    </StackPane>
                                    <Label fx:id="relatedHeadingLabel" text="More in this genre"
                                           styleClass="heading-lg"/>
                                </HBox>
                                <Separator/>
                                <Label fx:id="relatedEmptyLabel"
                                       text=""
                                       styleClass="caption"
                                       wrapText="true"
                                       managed="false" visible="false"/>
                                <ListView fx:id="relatedSongsListView"
                                          VBox.vgrow="ALWAYS"
                                          prefHeight="420"/>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <fx:include source="../musicplayer/controller/mini-player.fxml"/>
    </bottom>

</BorderPane>
