<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.settings.SettingsPageController"
            prefWidth="1280.0" prefHeight="820.0"
            minWidth="1180.0" minHeight="780.0"
            styleClass="page-bg">

    <top>
        <fx:include source="../chrome/app-top-bar.fxml"/>
    </top>

    <left>
        <fx:include source="../chrome/app-sidebar.fxml"/>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    styleClass="settings-scroll">
            <content>
                <VBox fx:id="settingsPageRoot" spacing="0" maxWidth="720" styleClass="settings-page-root">
                    <padding>
                        <Insets top="12" right="28" bottom="40" left="28"/>
                    </padding>

                    <VBox spacing="4" style="-fx-padding: 0 0 20 0;">
                        <Label text="Settings" styleClass="heading-xl"/>
                        <Label text="Tune playback defaults and appearance."
                               wrapText="true" maxWidth="640" styleClass="caption"/>
                    </VBox>

                    <Label text="Appearance" styleClass="settings-section-heading"/>
                    <VBox spacing="0" styleClass="card-elevated settings-panel">
                        <padding>
                            <Insets top="20" right="22" bottom="20" left="22"/>
                        </padding>
                        <Label text="Theme" styleClass="heading-sm"/>
                        <Label text="Applies to every screen, including the player and dialogs. "
                               wrapText="true" styleClass="body-sm" style="-fx-padding: 6 0 0 0;"/>
                        <Label fx:id="themeHintLabel" wrapText="true" styleClass="caption"
                               style="-fx-padding: 6 0 14 0;"/>
                        <Button fx:id="themeToggleButton" text="Switch theme"
                                onAction="#handleToggleTheme" styleClass="btn-accent-soft" prefHeight="40"/>
                    </VBox>

                    <Region prefHeight="22"/>

                    <Label text="Playback" styleClass="settings-section-heading"/>
                    <VBox spacing="0" styleClass="card-elevated settings-panel">
                        <padding>
                            <Insets top="20" right="22" bottom="20" left="22"/>
                        </padding>
                        <Label text="Shuffle" styleClass="heading-sm"/>
                        <Label text="When enabled, new sessions start with shuffle on. You can still toggle shuffle from the player at any time."
                               wrapText="true" styleClass="body-sm" style="-fx-padding: 6 0 12 0;"/>
                        <CheckBox fx:id="defaultShuffleCheckBox" text="Start signed-in sessions with shuffle on"
                                  onAction="#handleDefaultShuffleChanged" styleClass="body-sm"/>
                    </VBox>

                    <Region prefHeight="22"/>

                    <Label text="About" styleClass="settings-section-heading"/>
                    <VBox spacing="0" styleClass="card-elevated settings-panel">
                        <padding>
                            <Insets top="20" right="22" bottom="20" left="22"/>
                        </padding>
                        <Label text="TuneVault" styleClass="heading-sm"/>
                        <Label fx:id="aboutVersionLabel" text="" styleClass="body-sm"
                               style="-fx-padding: 6 0 0 0;"/>
                        <Label text="Desktop client for your personal music vault. Playback, playlists, "
                               wrapText="true" styleClass="caption" style="-fx-padding: 10 0 0 0;"/>
                        <Label text="recommendations, and Wrapped-style stats stay on your infrastructure."
                               wrapText="true" styleClass="caption"/>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <fx:include source="../musicplayer/controller/mini-player.fxml"/>
    </bottom>
</BorderPane>
