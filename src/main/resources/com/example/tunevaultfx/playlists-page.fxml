<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.playlist.PlaylistsPageController"
            prefWidth="1280.0" prefHeight="820.0"
            styleClass="page-bg">

    <top>
        <fx:include source="app-top-bar.fxml"/>
    </top>

    <!-- ── LEFT: app rail ─────────────────────────── -->
    <left>
        <fx:include source="app-sidebar.fxml"/>
    </left>
    <!-- ── CENTER: Scrollable two-column layout ──── -->
    <center>
        <StackPane alignment="TOP_LEFT"
                   style="-fx-padding: 16 32 16 32;"
                   maxWidth="Infinity" maxHeight="Infinity">

            <!-- Sidebar stays in the viewport; only the playlist detail column scrolls -->
            <HBox fx:id="contentRow" spacing="20" alignment="TOP_LEFT"
                  fillHeight="true" maxWidth="Infinity" maxHeight="Infinity"
                  style="-fx-padding: 0 0 24 0;">

                <VBox fx:id="playlistSidebarCard" spacing="12"
                      minWidth="280" prefWidth="280" maxWidth="280"
                      minHeight="0" maxHeight="Infinity"
                      HBox.hgrow="NEVER"
                      styleClass="card">

                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="Your Playlists" styleClass="heading-md"/>
                    </HBox>

                    <ListView fx:id="playlistListView"
                              VBox.vgrow="ALWAYS"
                              minHeight="120"/>

                    <VBox spacing="8" style="-fx-padding: 4 0 0 0;">
                        <Button text="+ New Playlist"
                                onAction="#handleCreatePlaylist"
                                maxWidth="Infinity"
                                styleClass="btn-primary"/>

                        <Button fx:id="deletePlaylistButton"
                                text="Delete Playlist"
                                onAction="#handleDeletePlaylist"
                                maxWidth="Infinity"
                                styleClass="btn-danger"/>
                    </VBox>
                </VBox>

                <ScrollPane fitToWidth="true" fitToHeight="false"
                            hbarPolicy="NEVER"
                            vbarPolicy="AS_NEEDED"
                            HBox.hgrow="ALWAYS"
                            minWidth="0" minHeight="0" maxHeight="Infinity">
                    <content>
                        <VBox spacing="0" minHeight="0">

                            <VBox fx:id="playlistSongsCard" spacing="12" styleClass="card">

                                <HBox alignment="CENTER_LEFT" spacing="14">
                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label fx:id="selectedPlaylistLabel"
                                               text="No playlist selected"
                                               styleClass="heading-lg"/>
                                        <HBox spacing="16" alignment="CENTER_LEFT">
                                            <Label fx:id="songCountLabel"
                                                   text="Songs: 0"
                                                   styleClass="body-sm, text-accent"/>
                                            <Label fx:id="totalDurationLabel"
                                                   text="Duration: 0:00"
                                                   styleClass="body-sm, text-accent"/>
                                        </HBox>
                                    </VBox>
                                    <Button text="+ Add Song"
                                            onAction="#handleShowSearchSongs"
                                            styleClass="btn-accent-soft"/>
                                </HBox>

                                <Separator/>

                                <ListView fx:id="playlistSongsListView" minHeight="160"/>

                                <VBox fx:id="suggestionsSection"
                                      spacing="12"
                                      visible="false"
                                      managed="false"
                                      styleClass="playlist-suggestions-block">

                                    <Separator/>

                                    <HBox alignment="CENTER_LEFT" spacing="12">
                                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                                            <Label text="Suggested for you" styleClass="heading-md"/>
                                            <Label fx:id="suggestionSubtitleLabel"
                                                   text="Based on this playlist and your listening history"
                                                   styleClass="caption"/>
                                        </VBox>
                                        <Label text="✦ Smart picks" styleClass="badge, badge-accent"/>
                                    </HBox>

                                    <ListView fx:id="suggestedSongsListView" minHeight="80"/>
                                </VBox>
                            </VBox>

                        </VBox>
                    </content>
                </ScrollPane>
            </HBox>

            <!-- Floating search panel (top-right overlay) -->
            <VBox fx:id="searchSongsPanel"
                  visible="false"
                  managed="false"
                  maxWidth="340" minWidth="340" prefWidth="340"
                  spacing="14"
                  StackPane.alignment="TOP_RIGHT"
                  translateX="-8"
                  styleClass="card-elevated">
                <children>

                    <HBox alignment="CENTER_LEFT">
                        <Label text="Add Songs" styleClass="heading-md"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="✕"
                                onAction="#handleHideSearchSongs"
                                prefWidth="36" prefHeight="36"
                                styleClass="btn-danger"/>
                    </HBox>

                    <TextField fx:id="searchSongsField"
                               promptText="Title, artist, album or genre…"
                               prefHeight="42"/>

                    <Label text="Double-click a row to play. Use + or the checkmark to add or remove from the playlist."
                           wrapText="true"
                           styleClass="caption"/>

                    <ListView fx:id="searchResultsListView"
                              VBox.vgrow="ALWAYS"
                              prefHeight="380"/>

                </children>
            </VBox>

        </StackPane>
    </center>

    <!-- ── BOTTOM ─────────────────────────────────── -->
    <bottom>
        <fx:include source="mini-player.fxml"/>
    </bottom>

</BorderPane>
