<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:id="sidebarRoot"
      fx:controller="com.example.tunevaultfx.chrome.AppSidebarController"
      styleClass="app-sidebar"
      prefWidth="262.0"
      minWidth="248.0"
      maxWidth="300.0"
      spacing="0">

    <padding>
        <Insets top="16" right="14" bottom="16" left="14"/>
    </padding>

    <!-- Brand -->
    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-brand"
          onMouseClicked="#handleBrandClick">
        <StackPane styleClass="sidebar-logo-mark" prefWidth="40" prefHeight="40"
                   minWidth="40" minHeight="40">
            <Label text="&#9835;" styleClass="sidebar-logo-glyph"/>
        </StackPane>
        <VBox spacing="1">
            <Label text="TuneVault" styleClass="sidebar-title"/>
            <Label text="Your music hub" styleClass="sidebar-tagline"/>
        </VBox>
    </HBox>

    <Region prefHeight="18"/>

    <!-- Primary nav (Spotify-style vertical rail) -->
    <VBox spacing="5" styleClass="sidebar-nav-block">
        <Button fx:id="navHome" text="Home" onAction="#goHome" styleClass="sidebar-nav-btn"
                maxWidth="Infinity" contentDisplay="LEFT" graphicTextGap="10">
            <graphic>
                <Label text="&#8962;" styleClass="sidebar-nav-icon" minWidth="26" alignment="CENTER"/>
            </graphic>
        </Button>
        <Button fx:id="navSearch" text="Search" onAction="#goSearch" styleClass="sidebar-nav-btn"
                maxWidth="Infinity" contentDisplay="LEFT" graphicTextGap="10">
            <graphic>
                <Label text="&#128269;" styleClass="sidebar-nav-icon" minWidth="26" alignment="CENTER"/>
            </graphic>
        </Button>
        <Button fx:id="navLibrary" text="Your Library" onAction="#goLibrary" styleClass="sidebar-nav-btn"
                maxWidth="Infinity" contentDisplay="LEFT" graphicTextGap="10">
            <graphic>
                <Label text="&#9776;" styleClass="sidebar-nav-icon" minWidth="26" alignment="CENTER"/>
            </graphic>
        </Button>
        <Button fx:id="navWrapped" text="Wrapped" onAction="#goWrapped" styleClass="sidebar-nav-btn"
                maxWidth="Infinity" contentDisplay="LEFT" graphicTextGap="10">
            <graphic>
                <Label text="&#10022;" styleClass="sidebar-nav-icon" minWidth="26" alignment="CENTER"/>
            </graphic>
        </Button>
        <Button fx:id="navGenre" text="Genre Quiz" onAction="#goGenre" styleClass="sidebar-nav-btn"
                maxWidth="Infinity" contentDisplay="LEFT" graphicTextGap="10">
            <graphic>
                <Label text="&#9835;" styleClass="sidebar-nav-icon" minWidth="26" alignment="CENTER"/>
            </graphic>
        </Button>
    </VBox>

    <Separator styleClass="sidebar-sep">
        <VBox.margin>
            <Insets top="16" bottom="12"/>
        </VBox.margin>
    </Separator>

    <Label text="Playlists in your library" styleClass="sidebar-library-heading"/>
    <Region prefHeight="8"/>

    <ListView fx:id="libraryListView" VBox.vgrow="ALWAYS" minHeight="120" prefHeight="200"
              styleClass="sidebar-library-list" focusTraversable="false"/>
</VBox>
