<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- Spotify-style: inset library column only (playlists). Outer shell adds page margin. -->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:id="sidebarRoot"
      fx:controller="com.example.tunevaultfx.chrome.AppSidebarController"
      styleClass="sidebar-outer"
      prefWidth="400.0"
      minWidth="320.0"
      maxWidth="560.0"
      spacing="0"
      VBox.vgrow="ALWAYS">

    <padding>
        <Insets top="12" right="14" bottom="12" left="18"/>
    </padding>

    <VBox styleClass="app-sidebar" spacing="0" VBox.vgrow="ALWAYS" maxWidth="Infinity">
        <padding>
            <Insets top="16" right="12" bottom="14" left="14"/>
        </padding>

        <Button text="+ Create playlist"
                onAction="#handleCreatePlaylistClick"
                maxWidth="Infinity"
                styleClass="sidebar-create-playlist"/>

        <Region prefHeight="12"/>

        <!-- Library header (Spotify "Your Library" emphasis) -->
        <VBox spacing="6" styleClass="sidebar-library-header">
            <Label text="Your Library" styleClass="sidebar-library-title"/>
            <Label text="Playlists" styleClass="sidebar-library-subtitle"/>
        </VBox>

        <Region prefHeight="12"/>

        <ListView fx:id="libraryListView" VBox.vgrow="ALWAYS" minHeight="160" prefHeight="280"
                  styleClass="sidebar-library-list" focusTraversable="false"/>
    </VBox>
</VBox>
