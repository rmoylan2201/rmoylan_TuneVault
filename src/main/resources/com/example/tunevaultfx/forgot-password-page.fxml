<?xml version="1.0" encoding="UTF-8"?>

        <?import javafx.scene.control.*?>
        <?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.controllers.auth.ForgotPasswordPageController"
            style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #1e293b);">

    <children>
        <VBox alignment="CENTER" spacing="18"
              AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <children>
                <Label text="Forgot Password"
                       style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" />

                <VBox spacing="12" maxWidth="360"
                      style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 25;">
                    <children>
                        <Label text="Enter your email"
                               style="-fx-text-fill: #334155; -fx-font-size: 13px; -fx-font-weight: bold;" />
                        <TextField fx:id="emailField" promptText="Enter email" />
                        <Button text="Submit"
                                onAction="#handleSubmit"
                                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-background-radius: 10;" />
                        <Button text="Back to Login"
                                onAction="#handleBackToLogin"
                                style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-background-radius: 10;" />
                        <Label fx:id="statusLabel" text="" wrapText="true" style="-fx-text-fill: #dc2626; -fx-font-size: 12px;" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>