<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.mainmenu.MainMenuController"
            prefWidth="1280.0" prefHeight="820.0"
            minWidth="1180.0" minHeight="780.0"
            styleClass="page-bg">

    <top>
        <fx:include source="app-top-bar.fxml"/>
    </top>

    <left>
        <fx:include source="app-sidebar.fxml"/>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <content>
                <VBox fx:id="menuContent" spacing="26" styleClass="page-content">

                    <!-- Hero -->
                    <VBox fx:id="homeHeroSection" spacing="8" styleClass="home-hero">
                        <Label fx:id="homeGreetingLabel" text="Welcome back" styleClass="heading-2xl"/>
                        <Label fx:id="homeStatsLabel" text="" styleClass="body-sm"/>
                    </VBox>

                    <!-- Libraries / quick shortcuts (sidebar has full list) -->
                    <VBox fx:id="homeLibrariesSection" spacing="12" styleClass="home-libraries">
                        <VBox spacing="4">
                            <HBox alignment="CENTER_LEFT" spacing="14">
                                <VBox spacing="2" HBox.hgrow="ALWAYS">
                                    <Label text="Jump back in" styleClass="heading-md"/>
                                    <Label text="Your playlists also live in the left sidebar, Spotify-style."
                                           styleClass="caption" wrapText="true"/>
                                </VBox>
                                <Button text="Open Library" onAction="#openPlaylistsPage" styleClass="btn-accent-soft"/>
                            </HBox>
                        </VBox>
                        <FlowPane fx:id="playlistChipsContainer" styleClass="home-playlist-grid"
                                  hgap="12" vgap="12"/>
                        <Label fx:id="noPlaylistsHint" managed="false" visible="false"
                               text="Create a playlist from Library to see it here."
                               styleClass="caption"/>
                    </VBox>

                    <!-- Discovery row -->
                    <HBox fx:id="homeFeedRow" spacing="20" alignment="TOP_LEFT">
                        <VBox fx:id="forYouFeedCard" spacing="12" styleClass="card" HBox.hgrow="ALWAYS" minWidth="320">
                            <VBox spacing="4">
                                <Label text="Picked for you" styleClass="heading-md"/>
                                <Label text="Personal picks from your taste profile" styleClass="caption"/>
                            </VBox>
                            <ListView fx:id="forYouListView" prefHeight="300" minHeight="200" VBox.vgrow="ALWAYS"/>
                        </VBox>
                        <VBox fx:id="freshTracksFeedCard" spacing="12" styleClass="card" HBox.hgrow="ALWAYS" minWidth="320">
                            <VBox spacing="4">
                                <Label text="Fresh in the vault" styleClass="heading-md"/>
                                <Label text="Newest tracks in the catalog" styleClass="caption"/>
                            </VBox>
                            <ListView fx:id="freshTracksListView" prefHeight="300" minHeight="200" VBox.vgrow="ALWAYS"/>
                        </VBox>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <fx:include source="mini-player.fxml"/>
    </bottom>
</BorderPane>
