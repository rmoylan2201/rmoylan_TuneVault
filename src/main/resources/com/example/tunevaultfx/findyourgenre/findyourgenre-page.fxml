<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.findyourgenre.FindYourGenrePageController"
            prefWidth="1280.0" prefHeight="820.0"
            minWidth="1180.0" minHeight="780.0"
            styleClass="page-bg">

    <top>
        <fx:include source="../chrome/app-top-bar.fxml"/>
    </top>

    <left>
        <fx:include source="../chrome/app-sidebar.fxml"/>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <content>
                <VBox fx:id="quizContainer" alignment="TOP_CENTER" spacing="20"
                      styleClass="page-content"
                      style="-fx-padding: 20 28 32 28;">

                    <VBox alignment="CENTER" spacing="8">
                        <Label text="Find your genre"
                               styleClass="heading-xl"
                               style="-fx-padding: 0 0 2 0;"/>
                        <Label fx:id="pageSubtitleLabel"
                               text="Choose Quick or Full, then Start quiz. Quick taps, no timer, no wrong answers — you can redo anytime. Keys 1–4 pick answers while the quiz runs."
                               wrapText="true"
                               maxWidth="720"
                               styleClass="caption"
                               textAlignment="CENTER"/>
                    </VBox>

                    <VBox fx:id="lengthPanel" alignment="CENTER" spacing="14" styleClass="genre-quiz-length-panel" maxWidth="760">
                        <Label text="QUIZ LENGTH" styleClass="genre-quiz-length-eyebrow"/>
                        <HBox alignment="CENTER" spacing="14" styleClass="genre-quiz-length-controls">
                            <HBox alignment="CENTER_LEFT" spacing="4" styleClass="genre-quiz-mode-segmented">
                                <RadioButton fx:id="modeQuickRadio" text="Quick · 5" selected="true"
                                             styleClass="genre-quiz-mode-pill"/>
                                <RadioButton fx:id="modeFullRadio" text="Full · 10"
                                             styleClass="genre-quiz-mode-pill"/>
                            </HBox>
                            <Button fx:id="startQuizButton" text="Start quiz" onAction="#handleStartQuiz"
                                    styleClass="genre-quiz-start-btn" minHeight="44" prefHeight="44"/>
                        </HBox>
                    </VBox>

                    <VBox fx:id="quizCard" spacing="0" alignment="TOP_CENTER"
                          maxWidth="760" prefWidth="760"
                          styleClass="card-elevated genre-quiz-card">

                        <!-- In-quiz and pre-start: progress, prompt, answers (answers hidden until quiz starts) -->
                        <VBox fx:id="quizActiveSection" spacing="22" alignment="TOP_CENTER"
                              styleClass="genre-quiz-active">
                            <VBox spacing="12" alignment="CENTER" styleClass="genre-quiz-progress-block">
                                <HBox alignment="CENTER" spacing="12">
                                    <StackPane styleClass="icon-box-sm, icon-box-violet">
                                        <Label text="♪" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #a78bfa;"/>
                                    </StackPane>
                                    <Label fx:id="progressLabel"
                                           text="Quick — 5 questions"
                                           styleClass="body-sm"/>
                                </HBox>
                                <ProgressBar fx:id="quizProgressBar" progress="0" maxWidth="Infinity"
                                             styleClass="genre-quiz-progress"/>
                            </VBox>

                            <Label fx:id="questionLabel"
                                   wrapText="true"
                                   text="Pick a length above, then tap Start quiz."
                                   maxWidth="640"
                                   alignment="CENTER"
                                   textAlignment="CENTER"
                                   styleClass="heading-lg"/>

                            <VBox fx:id="quizInteractiveSection" spacing="14" alignment="CENTER">
                                <GridPane hgap="12" vgap="12" alignment="CENTER">
                                    <columnConstraints>
                                        <ColumnConstraints prefWidth="300" hgrow="SOMETIMES"/>
                                        <ColumnConstraints prefWidth="300" hgrow="SOMETIMES"/>
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints prefHeight="72"/>
                                        <RowConstraints prefHeight="72"/>
                                    </rowConstraints>

                                    <Button fx:id="answerButton1" text="A" onAction="#handleAnswer1"
                                            GridPane.columnIndex="0" GridPane.rowIndex="0"
                                            maxWidth="Infinity" maxHeight="Infinity"
                                            styleClass="quiz-answer, genre-quiz-answer"
                                            wrapText="true"/>
                                    <Button fx:id="answerButton2" text="B" onAction="#handleAnswer2"
                                            GridPane.columnIndex="1" GridPane.rowIndex="0"
                                            maxWidth="Infinity" maxHeight="Infinity"
                                            styleClass="quiz-answer, genre-quiz-answer"
                                            wrapText="true"/>
                                    <Button fx:id="answerButton3" text="C" onAction="#handleAnswer3"
                                            GridPane.columnIndex="0" GridPane.rowIndex="1"
                                            maxWidth="Infinity" maxHeight="Infinity"
                                            styleClass="quiz-answer, genre-quiz-answer"
                                            wrapText="true"/>
                                    <Button fx:id="answerButton4" text="D" onAction="#handleAnswer4"
                                            GridPane.columnIndex="1" GridPane.rowIndex="1"
                                            maxWidth="Infinity" maxHeight="Infinity"
                                            styleClass="quiz-answer, genre-quiz-answer"
                                            wrapText="true"/>
                                </GridPane>

                                <HBox alignment="CENTER">
                                    <Button fx:id="skipQuestionButton" text="Skip this one — no points"
                                            onAction="#handleSkipQuestion"
                                            styleClass="btn-ghost, genre-quiz-skip"/>
                                </HBox>
                            </VBox>
                        </VBox>

                        <!-- Results-only: replaces quiz chrome so questions never compete with outcome -->
                        <VBox fx:id="resultSection" alignment="CENTER" spacing="0" visible="false" managed="false"
                              styleClass="genre-quiz-results">
                            <VBox alignment="CENTER" spacing="20" styleClass="genre-quiz-results-inner">
                                <Label fx:id="resultsEyebrowLabel" text="ALL SET"
                                       styleClass="genre-quiz-results-eyebrow"/>

                                <VBox alignment="CENTER" spacing="10">
                                    <Label fx:id="resultHeadlineLabel"
                                           wrapText="true" maxWidth="640" textAlignment="CENTER"
                                           styleClass="genre-quiz-results-headline"/>
                                    <Label fx:id="resultSummaryLabel"
                                           wrapText="true" maxWidth="620" textAlignment="CENTER"
                                           styleClass="genre-quiz-results-body"/>
                                </VBox>

                                <FlowPane fx:id="resultChips" hgap="12" vgap="12" alignment="CENTER"
                                          styleClass="genre-quiz-results-chips"/>

                                <Label fx:id="savedHintLabel"
                                       text=""
                                       wrapText="true" maxWidth="560"
                                       textAlignment="CENTER"
                                       styleClass="genre-quiz-results-hint"/>

                                <HBox fx:id="resultActionsRow" alignment="CENTER" spacing="12" styleClass="genre-quiz-results-actions">
                                    <Button fx:id="playMixButton" text="▶  Play my genre mix"
                                            onAction="#handlePlayMix"
                                            styleClass="btn-primary"
                                            prefHeight="46"/>
                                    <Button fx:id="restartButton" text="↺  Try again"
                                            onAction="#handleRestartQuiz"
                                            styleClass="btn-accent-soft"
                                            prefHeight="46"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <fx:include source="../musicplayer/controller/mini-player.fxml"/>
    </bottom>
</BorderPane>
