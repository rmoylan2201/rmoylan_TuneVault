<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.findyourgenre.FindYourGenrePageController"
            prefWidth="1280.0" prefHeight="820.0"
            minWidth="1180.0" minHeight="780.0"
            styleClass="page-bg">

    <top>
        <fx:include source="../chrome/app-top-bar.fxml"/>
    </top>

    <left>
        <fx:include source="../chrome/app-sidebar.fxml"/>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    styleClass="genre-quiz-scroll">
            <content>
                <VBox fx:id="quizContainer" alignment="TOP_LEFT" spacing="0" maxWidth="Infinity"
                      styleClass="page-content genre-quiz-page-root"
                      style="-fx-padding: 32 40 48 40;">

                    <VBox fx:id="genreQuizHero" spacing="12" styleClass="genre-quiz-hero" maxWidth="Infinity">
                        <Label text="Find your genre" styleClass="genre-quiz-page-title"/>
                        <Label fx:id="pageSubtitleLabel"
                               text="Choose Quick or Full, then Start quiz. Quick taps, no timer, no wrong answers — you can redo anytime."
                               wrapText="true" maxWidth="Infinity"
                               styleClass="genre-quiz-page-lede"/>
                    </VBox>

                    <Region prefHeight="28"/>

                    <HBox alignment="TOP_LEFT" spacing="36" maxWidth="Infinity" styleClass="genre-quiz-body-row">
                        <VBox HBox.hgrow="ALWAYS" maxWidth="Infinity" spacing="0"
                              styleClass="genre-quiz-main-column" minWidth="400">

                            <VBox fx:id="quizCard" spacing="0" alignment="TOP_LEFT"
                                  maxWidth="Infinity" minWidth="400"
                                  styleClass="card-elevated genre-quiz-card">

                                <!-- Progress: pick length + in-quiz (hidden on results) -->
                                <VBox fx:id="quizProgressBlock" spacing="14" maxWidth="Infinity"
                                      styleClass="genre-quiz-progress-wrap">
                                    <padding>
                                        <Insets top="28" right="32" bottom="8" left="32"/>
                                    </padding>
                                    <HBox alignment="CENTER_LEFT" spacing="14">
                                        <StackPane styleClass="icon-box-sm, icon-box-violet">
                                            <Label text="♪"
                                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #a78bfa;"/>
                                        </StackPane>
                                        <Label fx:id="progressLabel" text="Quick — 5 questions"
                                               styleClass="genre-quiz-progress-label"/>
                                    </HBox>
                                    <ProgressBar fx:id="quizProgressBar" progress="0" maxWidth="Infinity"
                                                 prefHeight="10" minHeight="10"
                                                 styleClass="genre-quiz-progress"/>
                                </VBox>

                                <!-- Length: large two-column chooser + start -->
                                <VBox fx:id="lengthPanel" alignment="TOP_LEFT" spacing="20" maxWidth="Infinity"
                                      styleClass="genre-quiz-length-hero">
                                    <padding>
                                        <Insets top="8" right="32" bottom="32" left="32"/>
                                    </padding>
                                    <Label text="How deep should we go?" styleClass="genre-quiz-length-title"/>
                                    <Label text="Same vibe either way — Full adds five more prompts for a richer blend."
                                           wrapText="true" maxWidth="Infinity"
                                           styleClass="genre-quiz-length-sub"/>

                                    <HBox spacing="18" alignment="TOP_LEFT" maxWidth="Infinity">
                                        <VBox fx:id="quickModeOffer" styleClass="genre-quiz-mode-offer" spacing="10"
                                              HBox.hgrow="ALWAYS" minWidth="200">
                                            <RadioButton fx:id="modeQuickRadio" text="Quick"
                                                         styleClass="genre-quiz-mode-pill"
                                                         wrapText="true"/>
                                            <Label text="5 questions · about two minutes"
                                                   styleClass="genre-quiz-mode-meta"/>
                                            <Label text="Fast taste snapshot. Ideal when you want recommendations tuned without a long session."
                                                   wrapText="true" maxWidth="Infinity"
                                                   styleClass="genre-quiz-mode-blurb"/>
                                        </VBox>
                                        <VBox fx:id="fullModeOffer" styleClass="genre-quiz-mode-offer" spacing="10"
                                              HBox.hgrow="ALWAYS" minWidth="200">
                                            <RadioButton fx:id="modeFullRadio" text="Full"
                                                         styleClass="genre-quiz-mode-pill"
                                                         wrapText="true"/>
                                            <Label text="10 questions · fuller profile"
                                                   styleClass="genre-quiz-mode-meta"/>
                                            <Label text="More scenes to express nuance. Better if you’re fine spending a little longer."
                                                   wrapText="true" maxWidth="Infinity"
                                                   styleClass="genre-quiz-mode-blurb"/>
                                        </VBox>
                                    </HBox>

                                    <HBox alignment="CENTER_LEFT" maxWidth="Infinity" style="-fx-padding: 8 0 0 0;">
                                        <Button fx:id="startQuizButton" text="Start quiz"
                                                onAction="#handleStartQuiz"
                                                styleClass="genre-quiz-start-btn"
                                                minHeight="52" prefHeight="52" minWidth="260"/>
                                    </HBox>
                                </VBox>

                                <!-- In-quiz: prompt + answers only -->
                                <VBox fx:id="quizQuestionSection" spacing="22" alignment="TOP_CENTER"
                                      maxWidth="Infinity" styleClass="genre-quiz-question-wrap">
                                    <padding>
                                        <Insets top="12" right="32" bottom="36" left="32"/>
                                    </padding>
                                    <Label fx:id="questionLabel"
                                           wrapText="true"
                                           text="Pick a length above, then tap Start quiz."
                                           maxWidth="Infinity"
                                           alignment="TOP_LEFT"
                                           textAlignment="LEFT"
                                           styleClass="genre-quiz-question"/>

                                    <VBox fx:id="quizInteractiveSection" spacing="18" alignment="TOP_CENTER"
                                          maxWidth="Infinity">
                                        <GridPane hgap="16" vgap="16" alignment="CENTER" maxWidth="Infinity">
                                            <columnConstraints>
                                                <ColumnConstraints minWidth="260" hgrow="ALWAYS"/>
                                                <ColumnConstraints minWidth="260" hgrow="ALWAYS"/>
                                            </columnConstraints>
                                            <rowConstraints>
                                                <RowConstraints minHeight="96" prefHeight="104" vgrow="SOMETIMES"/>
                                                <RowConstraints minHeight="96" prefHeight="104" vgrow="SOMETIMES"/>
                                            </rowConstraints>

                                            <Button fx:id="answerButton1" text="A" onAction="#handleAnswer1"
                                                    GridPane.columnIndex="0" GridPane.rowIndex="0"
                                                    maxWidth="Infinity" maxHeight="Infinity"
                                                    styleClass="quiz-answer, genre-quiz-answer"
                                                    wrapText="true"/>
                                            <Button fx:id="answerButton2" text="B" onAction="#handleAnswer2"
                                                    GridPane.columnIndex="1" GridPane.rowIndex="0"
                                                    maxWidth="Infinity" maxHeight="Infinity"
                                                    styleClass="quiz-answer, genre-quiz-answer"
                                                    wrapText="true"/>
                                            <Button fx:id="answerButton3" text="C" onAction="#handleAnswer3"
                                                    GridPane.columnIndex="0" GridPane.rowIndex="1"
                                                    maxWidth="Infinity" maxHeight="Infinity"
                                                    styleClass="quiz-answer, genre-quiz-answer"
                                                    wrapText="true"/>
                                            <Button fx:id="answerButton4" text="D" onAction="#handleAnswer4"
                                                    GridPane.columnIndex="1" GridPane.rowIndex="1"
                                                    maxWidth="Infinity" maxHeight="Infinity"
                                                    styleClass="quiz-answer, genre-quiz-answer"
                                                    wrapText="true"/>
                                        </GridPane>

                                        <HBox alignment="CENTER" maxWidth="Infinity">
                                            <Button fx:id="skipQuestionButton" text="Skip this one — no points"
                                                    onAction="#handleSkipQuestion"
                                                    styleClass="btn-ghost, genre-quiz-skip"/>
                                        </HBox>
                                    </VBox>
                                </VBox>

                                <!-- Results -->
                                <VBox fx:id="resultSection" alignment="TOP_LEFT" spacing="0" visible="false"
                                      managed="false" styleClass="genre-quiz-results">
                                    <VBox alignment="TOP_LEFT" spacing="24" maxWidth="Infinity"
                                          styleClass="genre-quiz-results-inner">
                                        <padding>
                                            <Insets top="36" right="40" bottom="44" left="40"/>
                                        </padding>
                                        <Label fx:id="resultsEyebrowLabel" text="YOUR GENRE PROFILE"
                                               styleClass="genre-quiz-results-eyebrow"/>

                                        <VBox alignment="TOP_LEFT" spacing="14" maxWidth="Infinity">
                                            <Label fx:id="resultHeadlineLabel"
                                                   wrapText="true" maxWidth="Infinity" textAlignment="LEFT"
                                                   styleClass="genre-quiz-results-headline"/>
                                            <Label fx:id="resultSummaryLabel"
                                                   wrapText="true" maxWidth="Infinity" textAlignment="LEFT"
                                                   styleClass="genre-quiz-results-body"/>
                                        </VBox>

                                        <FlowPane fx:id="resultChips" hgap="12" vgap="12" alignment="TOP_LEFT"
                                                  maxWidth="Infinity" styleClass="genre-quiz-results-chips"/>

                                        <Label fx:id="savedHintLabel" text="" wrapText="true" maxWidth="Infinity"
                                               textAlignment="LEFT" styleClass="genre-quiz-results-hint"/>

                                        <HBox fx:id="resultActionsRow" alignment="CENTER_LEFT" spacing="14"
                                              styleClass="genre-quiz-results-actions">
                                            <Button fx:id="playMixButton" text="▶  Play my genre mix"
                                                    onAction="#handlePlayMix"
                                                    styleClass="btn-primary" prefHeight="50" minHeight="50"/>
                                            <Button fx:id="restartButton" text="↺  Try again"
                                                    onAction="#handleRestartQuiz"
                                                    styleClass="btn-accent-soft" prefHeight="50" minHeight="50"/>
                                        </HBox>
                                    </VBox>
                                </VBox>
                            </VBox>
                        </VBox>

                        <VBox fx:id="genreQuizSideRail" spacing="20" prefWidth="320" minWidth="280" maxWidth="360"
                              styleClass="genre-quiz-side-rail">
                            <Label text="Why run this" styleClass="genre-quiz-side-rail-eyebrow"/>
                            <Label wrapText="true" maxWidth="Infinity" styleClass="genre-quiz-side-rail-body"
                                   text="Your answers become genre affinities saved to your account. They merge into recommendations, search ranking, Wrapped summaries, and autoplay when you’re signed in."/>
                            <Region prefHeight="8"/>
                            <Label text="Tips" styleClass="genre-quiz-side-rail-eyebrow"/>
                            <Label wrapText="true" maxWidth="Infinity" styleClass="genre-quiz-side-rail-body"
                                   text="Keys 1–4 pick answers. Skip is fine — it only skips points for that question. You can retake the quiz anytime to refresh your saved mix."/>
                        </VBox>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <fx:include source="../musicplayer/controller/mini-player.fxml"/>
    </bottom>
</BorderPane>
