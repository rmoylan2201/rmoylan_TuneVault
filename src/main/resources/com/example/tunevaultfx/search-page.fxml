<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.search.SearchPageController"
            prefWidth="1280.0"
            prefHeight="760.0"
            style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #1e293b);">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 20 24 18 24;">
            <children>
                <Button text="Back to Menu"
                        onAction="#handleBackToMenu"
                        prefWidth="125"
                        prefHeight="40"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 20;" />

                <StackPane HBox.hgrow="ALWAYS" alignment="CENTER">
                    <Label text="Search"
                           style="-fx-text-fill: white; -fx-font-size: 30px; -fx-font-weight: bold;" />
                </StackPane>

                <Region prefWidth="125" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding: 12 24 20 24;">
            <children>

                <VBox spacing="12"
                      style="-fx-background-color: #f8fafc; -fx-background-radius: 24; -fx-padding: 22;">
                    <children>
                        <Label text="What do you want to play?"
                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />

                        <HBox spacing="12">
                            <children>
                                <TextField fx:id="searchField"
                                           HBox.hgrow="ALWAYS"
                                           promptText="Search songs, artists, albums, or genres"
                                           prefHeight="46"
                                           style="-fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #cbd5e1; -fx-font-size: 14px;" />

                                <Button text="Clear"
                                        onAction="#handleClearSearch"
                                        prefWidth="110"
                                        prefHeight="46"
                                        style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 18;" />
                            </children>
                        </HBox>

                        <Label fx:id="resultsSummaryLabel"
                               text="Start typing to search."
                               style="-fx-text-fill: #64748b; -fx-font-size: 14px;" />
                    </children>
                </VBox>

                <VBox fx:id="recentSection"
                      spacing="18"
                      VBox.vgrow="ALWAYS"
                      style="-fx-background-color: #f8fafc; -fx-background-radius: 24; -fx-padding: 22;">
                    <children>

                        <VBox spacing="12">
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Suggested for you"
                                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                                    </children>
                                </HBox>

                                <ListView fx:id="suggestedSongsListView"
                                          prefHeight="220"
                                          maxHeight="220"
                                          style="-fx-background-radius: 12; -fx-border-radius: 12;" />
                            </children>
                        </VBox>

                        <VBox spacing="12" VBox.vgrow="ALWAYS">
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Recent searches"
                                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button text="Clear All"
                                                onAction="#handleClearRecentSearches"
                                                prefWidth="110"
                                                prefHeight="38"
                                                style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 18;" />
                                    </children>
                                </HBox>

                                <ListView fx:id="recentSearchesListView"
                                          VBox.vgrow="ALWAYS"
                                          prefHeight="280"
                                          style="-fx-background-radius: 12; -fx-border-radius: 12;" />
                            </children>
                        </VBox>

                    </children>
                </VBox>

                <HBox fx:id="resultsSection"
                      spacing="24"
                      VBox.vgrow="ALWAYS"
                      visible="false"
                      managed="false">
                    <children>
                        <VBox spacing="14"
                              prefWidth="760"
                              HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #f8fafc; -fx-background-radius: 24; -fx-padding: 22;">
                            <children>
                                <Label text="Songs"
                                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />

                                <ListView fx:id="songResultsListView"
                                          VBox.vgrow="ALWAYS"
                                          prefHeight="520"
                                          style="-fx-background-radius: 12; -fx-border-radius: 12;" />
                            </children>
                        </VBox>

                        <VBox spacing="14"
                              minWidth="320"
                              prefWidth="340"
                              maxWidth="340"
                              style="-fx-background-color: #f8fafc; -fx-background-radius: 24; -fx-padding: 22;">
                            <children>
                                <Label text="Artists"
                                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />

                                <ListView fx:id="artistResultsListView"
                                          VBox.vgrow="ALWAYS"
                                          prefHeight="520"
                                          style="-fx-background-radius: 12; -fx-border-radius: 12;" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

            </children>
        </VBox>
    </center>

    <bottom>
        <fx:include source="mini-player.fxml" />
    </bottom>
</BorderPane>