<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.settings.SettingsPageController"
            prefWidth="1280.0" prefHeight="820.0"
            minWidth="1180.0" minHeight="780.0"
            styleClass="page-bg">

    <top>
        <fx:include source="../chrome/app-top-bar.fxml"/>
    </top>

    <left>
        <fx:include source="../chrome/app-sidebar.fxml"/>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    styleClass="settings-scroll">
            <content>
                <VBox fx:id="settingsPageRoot" spacing="0" maxWidth="Infinity"
                      styleClass="settings-page-root">
                    <padding>
                        <Insets top="36" right="44" bottom="64" left="44"/>
                    </padding>

                    <!-- Hero -->
                    <VBox spacing="12" styleClass="settings-hero">
                        <Label text="Settings" styleClass="settings-page-title"/>
                        <Label text="Choose how TuneVault looks and behaves. These preferences apply across the whole app, including the mini player and dialogs."
                               wrapText="true" maxWidth="Infinity"
                               styleClass="settings-lede"/>
                    </VBox>

                    <Region prefHeight="40"/>

                    <HBox spacing="44" alignment="TOP_LEFT" styleClass="settings-columns">
                        <!-- Left column -->
                        <VBox spacing="40" HBox.hgrow="ALWAYS" minWidth="340" styleClass="settings-column">
                            <VBox spacing="0">
                                <Label text="Appearance" styleClass="settings-section-title"/>
                                <VBox spacing="16" styleClass="card-elevated settings-panel">
                                    <padding>
                                        <Insets top="28" right="32" bottom="32" left="32"/>
                                    </padding>
                                    <Label text="Theme" styleClass="settings-card-heading"/>
                                    <Label text="Switch between dark and light. The top bar and every screen follow this choice."
                                           wrapText="true" maxWidth="Infinity"
                                           styleClass="settings-body"/>
                                    <Label fx:id="themeHintLabel" wrapText="true" maxWidth="Infinity"
                                           styleClass="settings-hint"/>
                                    <Button fx:id="themeToggleButton" text="Switch theme"
                                            onAction="#handleToggleTheme" styleClass="btn-accent-soft"
                                            prefHeight="46" minHeight="46" maxWidth="280"
                                            focusTraversable="false"/>
                                </VBox>
                            </VBox>

                            <VBox spacing="0">
                                <Label text="Playback" styleClass="settings-section-title"/>
                                <VBox spacing="16" styleClass="card-elevated settings-panel">
                                    <padding>
                                        <Insets top="28" right="32" bottom="32" left="32"/>
                                    </padding>
                                    <Label text="Shuffle" styleClass="settings-card-heading"/>
                                    <Label text="When this is on, each time you sign in the player starts with shuffle enabled. You can still change it from the player at any time."
                                           wrapText="true" maxWidth="Infinity"
                                           styleClass="settings-body"/>
                                    <CheckBox fx:id="defaultShuffleCheckBox"
                                              text="Start new sessions with shuffle on"
                                              onAction="#handleDefaultShuffleChanged"
                                              styleClass="settings-shuffle-check"
                                              wrapText="true" maxWidth="Infinity"/>
                                </VBox>
                            </VBox>
                        </VBox>

                        <!-- Right column -->
                        <VBox spacing="40" HBox.hgrow="ALWAYS" minWidth="340" styleClass="settings-column">
                            <VBox spacing="0">
                                <Label text="Account" styleClass="settings-section-title"/>
                                <VBox spacing="16" styleClass="card-elevated settings-panel">
                                    <padding>
                                        <Insets top="28" right="32" bottom="32" left="32"/>
                                    </padding>
                                    <Label text="Delete account" styleClass="settings-card-heading"/>
                                    <Label text="Permanently removes your playlists, listening history, follows, and profile data. You will confirm in a dialog and enter your password."
                                           wrapText="true" maxWidth="Infinity"
                                           styleClass="settings-body"/>
                                    <Button text="Delete account…" onAction="#handleDeleteAccount"
                                            styleClass="btn-danger" prefHeight="46" minHeight="46"
                                            maxWidth="280" focusTraversable="false"/>
                                </VBox>
                            </VBox>

                            <VBox spacing="0">
                                <Label text="About" styleClass="settings-section-title"/>
                                <VBox spacing="14" styleClass="card-elevated settings-panel">
                                    <padding>
                                        <Insets top="28" right="32" bottom="32" left="32"/>
                                    </padding>
                                    <Label text="TuneVault" styleClass="settings-card-heading"/>
                                    <Label fx:id="aboutVersionLabel" text="" styleClass="settings-about-version"/>
                                    <Label text="Desktop client for your personal music vault — playback, playlists, recommendations, and Wrapped-style stats stay on your infrastructure."
                                           wrapText="true" maxWidth="Infinity"
                                           styleClass="settings-body"/>
                                </VBox>
                            </VBox>
                        </VBox>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <fx:include source="../musicplayer/controller/mini-player.fxml"/>
    </bottom>
</BorderPane>
